# ── Общий .env для docker-compose (сборка на сервере) ────────────────────────
# Скопируйте в .env и заполните. Это единственный файл, который нужно
# редактировать при деплое — docker-compose.yml читает именно его.
# Для локального запуска без Docker см. backend/.env.example и frontend/.env.

# ── Публичные адреса ──────────────────────────────────────────────────────────
# На реальном сервере — настоящий домен с https://.
FRONTEND_PUBLIC_URL=http://127.0.0.1:5173
BACKEND_PUBLIC_URL=http://127.0.0.1:8001

# ── AI-провайдер: "anthropic" | "groq" | "openai" | "fake" ──────────────────
JEVAL_AGENT_PROVIDER=openai

ANTHROPIC_API_KEY=sk-ant-...
JEVAL_MODEL=claude-opus-4-8

GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── База данных (сервис db в docker-compose.yml) ─────────────────────────────
# Обязательно смените пароль перед реальным деплоем.
POSTGRES_DB=jeval
POSTGRES_USER=jeval
POSTGRES_PASSWORD=jeval

# ── Сервис ────────────────────────────────────────────────────────────────────
JEVAL_ENV=production
JEVAL_AUTH_REQUIRED=true
JEVAL_SESSION_DAYS=30
JEVAL_ALLOW_FAKE_IN_PROD=false

# Google OAuth
JEVAL_GOOGLE_ENABLED=1
JEVAL_GOOGLE_CLIENT_ID=
JEVAL_GOOGLE_CLIENT_SECRET=

# Allowlist/инвайты для входа через Google — false = прод-режим (без обхода).
JEVAL_DISABLE_ACCESS_GATE=false
