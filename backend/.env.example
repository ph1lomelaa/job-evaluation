# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-...
# Модель агента-оценщика. По умолчанию — последняя Opus.
JEVAL_MODEL=claude-opus-4-8

# Офлайн-режим без ключа: уровни выбирает детерминированная заглушка (демо/разработка).
JEVAL_FAKE_AGENT=0

# Сервис
JEVAL_HOST=127.0.0.1
JEVAL_PORT=8000
JEVAL_ENV=development

# Хранилище
JEVAL_DB_URL=sqlite:///./jeval.db
