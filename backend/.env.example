# ── Выбор провайдера: "anthropic" | "groq" | "fake" ──────────────────────────
# "fake" = офлайн-режим без ключа (демо / разработка). Результат помечается
# Evaluation.is_test_data=true и не годится для реального Оценочного комитета.
# В JEVAL_ENV=production "fake"/JEVAL_FAKE_AGENT=1 заблокированы, если не задан
# второй явный флаг JEVAL_ALLOW_FAKE_IN_PROD=1 (см. api/deps.get_evaluator).
JEVAL_AGENT_PROVIDER=fake
JEVAL_ALLOW_FAKE_IN_PROD=false

# Anthropic / Claude (нужен при JEVAL_AGENT_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
JEVAL_MODEL=claude-opus-4-8

# Groq (нужен при JEVAL_AGENT_PROVIDER=groq)
# Ключ: https://console.groq.com/keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Сервис
# ВНИМАНИЕ: JEVAL_HOST/JEVAL_PORT ничего не меняют при запуске `uvicorn
# jeval.api.main:app --reload` (см. README) — uvicorn слушает свой собственный
# дефолтный порт 8000, если вы не передали ему `--port` явно. Dockerfile тоже
# хардкодит `--port 8000` в CMD и не читает эти переменные. Если вы запускаете
# backend на порту, отличном от 8000 (например, 8001 — как в docker-compose.yml
# через маппинг "8001:8000"), убедитесь, что JEVAL_GOOGLE_REDIRECT_URI ниже
# указывает именно на тот порт, на котором сервер РЕАЛЬНО слушает снаружи —
# иначе Google вернёт "Error 400: redirect_uri_mismatch" или callback не дойдёт.
JEVAL_HOST=127.0.0.1
JEVAL_PORT=8000
JEVAL_ENV=development

# Авторизация и срок серверной сессии
JEVAL_AUTH_REQUIRED=true
JEVAL_SESSION_DAYS=30

# Google OAuth (вход через Google). JEVAL_GOOGLE_REDIRECT_URI отправляется в
# Google БУКВАЛЬНО как есть (см. jeval/api/routers/auth.py: google_start() и
# _fetch_google_profile()) — это не собирается из host/port/схемы в коде, это
# один литерал. Он должен СИМВОЛЬНО совпадать (схема, домен, порт, путь, наличие
# /отсутствие trailing slash) со строкой в Google Cloud Console → Credentials →
# этот OAuth client → Authorized redirect URIs. Несовпадение даёт
# "Error 400: redirect_uri_mismatch".
JEVAL_GOOGLE_ENABLED=false
JEVAL_GOOGLE_CLIENT_ID=
JEVAL_GOOGLE_CLIENT_SECRET=
JEVAL_GOOGLE_REDIRECT_URI=http://127.0.0.1:8001/api/auth/google/callback

# ВРЕМЕННО для разработки, не включать в проде: пропускает allowlist/приглашение
# при первом входе через Google (см. google_callback в jeval/api/routers/auth.py).
# RBAC после входа (роли owner/admin/evaluator/viewer) не отключается — только
# допуск к созданию аккаунта без приглашения. При true сервис при старте пишет
# в лог "ACCESS GATE DISABLED — DEV ONLY". По умолчанию false.
JEVAL_DISABLE_ACCESS_GATE=false

# Хранилище
JEVAL_DB_URL=sqlite:///./jeval.db
JEVAL_UPLOAD_DIR=uploads
