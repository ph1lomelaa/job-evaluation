# ── Выбор провайдера: "anthropic" | "groq" | "fake" ──────────────────────────
# "fake" = офлайн-режим без ключа (демо / разработка)
JEVAL_AGENT_PROVIDER=fake

# Anthropic / Claude (нужен при JEVAL_AGENT_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
JEVAL_MODEL=claude-opus-4-8

# Groq (нужен при JEVAL_AGENT_PROVIDER=groq)
# Ключ: https://console.groq.com/keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Сервис
JEVAL_HOST=127.0.0.1
JEVAL_PORT=8000
JEVAL_ENV=development

# Авторизация и срок серверной сессии
JEVAL_AUTH_REQUIRED=true
JEVAL_SESSION_DAYS=30

# Хранилище
JEVAL_DB_URL=sqlite:///./jeval.db
JEVAL_UPLOAD_DIR=uploads
