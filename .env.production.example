# Public address (without https://)
DOMAIN=job-evaluation.duckdns.org
# Same hostname escaped for a regular expression
DOMAIN_REGEX=job-evaluation\.duckdns\.org
# Existing Docker network used by the server's shared Caddy container
CADDY_NETWORK=caddy_network

# PostgreSQL: replace with a long random password
POSTGRES_DB=jeval
POSTGRES_USER=jeval
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD

# Browser uses the same origin; keep this empty
VITE_API_URL=

# Google OAuth client from Google Cloud Console
JEVAL_GOOGLE_ENABLED=true
JEVAL_GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
JEVAL_GOOGLE_CLIENT_SECRET=CHANGE_ME

# Production safety
JEVAL_ENV=production
JEVAL_AUTH_REQUIRED=true
JEVAL_REGISTRATION_ENABLED=true
JEVAL_DISABLE_ACCESS_GATE=true
JEVAL_FAKE_AGENT=false
JEVAL_ALLOW_FAKE_IN_PROD=false

# LLM provider (fill the selected provider key)
JEVAL_AGENT_PROVIDER=openai
OPENAI_API_KEY=CHANGE_ME
OPENAI_MODEL=gpt-4o-mini
